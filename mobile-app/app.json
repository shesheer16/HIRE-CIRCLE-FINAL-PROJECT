{
  "expo": {
    "name": "HireCircle",
    "slug": "hirecircle",
    "version": "1.0.0",
    "jsEngine": "hermes",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "HireCircle needs camera access to capture your interview and profile videos.",
        "NSMicrophoneUsageDescription": "HireCircle needs microphone access to record audio with your interview videos.",
        "NSUserNotificationUsageDescription": "HireCircle uses notifications for chat messages, application updates, and matches."
      }
    },
    "android": {
      "package": "com.lokesh.hirecircle",
      "versionCode": 10,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": false
    },
    "androidStatusBar": {
      "backgroundColor": "#0f172a",
      "barStyle": "light-content",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#0f172a",
      "barStyle": "light-content"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "HireCircle needs camera access to capture your interview and profile videos.",
          "microphonePermission": "HireCircle needs microphone access to record audio with your interview videos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#5b21b6"
        }
      ],
      "expo-document-picker"
    ],
    "extra": {
      "privacyPolicyUrl": "https://hirecircle.in/privacy",
      "eas": {
        "projectId": "0feb4698-0350-474c-ad6e-521ae3337adb"
      }
    },
    "owner": "lokesh888"
  }
}
