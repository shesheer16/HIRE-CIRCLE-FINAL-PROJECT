{
  "family": "hireapp-interview-worker-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::123456789012:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::123456789012:role/hireapp-worker-task-role",
  "containerDefinitions": [
    {
      "name": "interview-worker",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/hireapp-backend:latest",
      "essential": true,
      "command": ["npm", "run", "worker:interview"],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "INTERVIEW_WORKER_CONCURRENCY", "value": "5" },
        { "name": "INTERVIEW_WORKER_POLL_WAIT_SECONDS", "value": "20" },
        { "name": "INTERVIEW_PROCESSING_TIMEOUT_MS", "value": "300000" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hireapp-interview-worker",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
