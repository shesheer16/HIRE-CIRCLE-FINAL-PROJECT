# Production environment template
NODE_ENV=production
PORT=5001

MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
REDIS_URL=rediss://<host>:6379
REDIS_ENABLED=true
AWS_SQS_INTERVIEW_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account>/<queue-name>

JWT_SECRET=<min_32_char_random_secret>
JWT_REFRESH_SECRET=<min_32_char_random_secret>
OTP_HMAC_SECRET=<min_32_char_random_secret>
SMART_INTERVIEW_DATASET_SALT=<min_32_char_random_secret>

CORS_ORIGINS=https://app.hirecircle.in
API_PUBLIC_URL=https://api.hirecircle.in
FRONTEND_URL=https://app.hirecircle.in

GEMINI_API_KEY=<gemini_api_key>

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_EMAIL=<smtp_username>
SMTP_PASSWORD=<smtp_password>
FROM_EMAIL=no-reply@hirecircle.in
FROM_NAME=HireCircle
SMTP_REQUIRE_TLS=true
SMTP_VERIFIED_FROM_DOMAIN=hirecircle.in
SMTP_DKIM_SELECTOR=<dkim_selector>
SMTP_DKIM_DOMAIN=hirecircle.in
SMTP_SPF_RECORD=v=spf1 include:sendgrid.net ~all

TWILIO_ACCOUNT_SID=<twilio_account_sid>
TWILIO_AUTH_TOKEN=<twilio_auth_token>
TWILIO_FROM_PHONE=+10000000000

AWS_ACCESS_KEY_ID=<aws_access_key>
AWS_SECRET_ACCESS_KEY=<aws_secret_key>
AWS_REGION=ap-south-2
AWS_BUCKET_NAME=<aws_bucket_name>

STRIPE_SECRET_KEY=<stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<stripe_webhook_secret>
STRIPE_PRICE_PRO=<stripe_price_id>
