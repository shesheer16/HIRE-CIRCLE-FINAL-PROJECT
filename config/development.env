# DEVELOPMENT ENVIRONMENT

NODE_ENV=development
PORT=5001

# MongoDB Local or Atlas Dev Cluster
MONGO_URI=mongodb://localhost:27017/hireapp_dev
AWS_SQS_INTERVIEW_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account>/<queue-name>
SMART_INTERVIEW_DATASET_SALT=<min_32_char_random_secret>

# JWT & Security
JWT_SECRET=<min_32_char_random_secret>
JWT_SECRET_REFRESH=<min_32_char_random_secret>

# S3 & CDN (Localstack or Dev Sandbox)
AWS_ACCESS_KEY_ID=<aws_access_key>
AWS_SECRET_ACCESS_KEY=<aws_secret_key>
AWS_REGION=us-east-1
AWS_BUCKET_NAME=hireapp-dev-bucket
AWS_CLOUDFRONT_URL=

# Gemini Matchmaking
GEMINI_API_KEY=<gemini_api_key>

# Stripe (Test Mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# Sentry
SENTRY_DSN=

# Globalization & Multi-Region Readiness
SYSTEM_BASE_CURRENCY=USD
DEFAULT_COUNTRY_CODE=IN
DEFAULT_TIMEZONE=UTC
APP_REGION=us-east-1
APP_REGION_MAP={"us-east-1":{"dbWriteUri":"mongodb://localhost:27017/hireapp_dev","redisUrl":"redis://localhost:6379","staticAssetsBaseUrl":""}}
MONGO_URI_BY_REGION_JSON={"us-east-1":"mongodb://localhost:27017/hireapp_dev"}
REDIS_URL_BY_REGION_JSON={"us-east-1":"redis://localhost:6379"}
AWS_BUCKET_BY_REGION_JSON={"us-east-1":"hireapp-dev-bucket"}
CURRENCY_CONVERSION_RATES_JSON={"USD":1,"INR":83,"EUR":0.92,"GBP":0.78,"CAD":1.34,"SGD":1.35,"AED":3.67}
ASSET_PUBLIC_BASE_URL=
