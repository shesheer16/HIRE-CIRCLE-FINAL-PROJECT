# PRODUCTION ENVIRONMENT

NODE_ENV=production
PORT=5001

# MongoDB Atlas Production Cluster
MONGO_URI=mongodb+srv://<user>:<password>@cluster-prod.mongodb.net/hireapp_prod?retryWrites=true&w=majority
AWS_SQS_INTERVIEW_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account>/<queue-name>
SMART_INTERVIEW_DATASET_SALT=<min_32_char_random_secret>

# JWT & Security (Fetched from Secrets Manager dynamically)
# JWT_SECRET=
# JWT_SECRET_REFRESH=

# S3 & CDN
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=hireapp-prod-bucket
AWS_CLOUDFRONT_URL=https://cdn.hireapp.com

# Gemini Matchmaking
# GEMINI_API_KEY=

# Stripe (Live Mode)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...

# Sentry
# SENTRY_DSN=

# Globalization & Multi-Region Readiness
SYSTEM_BASE_CURRENCY=USD
DEFAULT_COUNTRY_CODE=US
DEFAULT_TIMEZONE=UTC
APP_REGION=us-east-1
# Example: {"us-east-1":{"dbWriteUri":"...","dbReadReplicaUri":"...","redisUrl":"...","staticAssetsBaseUrl":"https://cdn.hireapp.com"},"eu-west-1":{"dbWriteUri":"...","dbReadReplicaUri":"...","redisUrl":"...","staticAssetsBaseUrl":"https://eu-cdn.hireapp.com"}}
APP_REGION_MAP={}
MONGO_URI_BY_REGION_JSON={}
REDIS_URL_BY_REGION_JSON={}
AWS_BUCKET_BY_REGION_JSON={}
CURRENCY_CONVERSION_RATES_JSON={"USD":1,"INR":83,"EUR":0.92,"GBP":0.78,"CAD":1.34,"SGD":1.35,"AED":3.67}
ASSET_PUBLIC_BASE_URL=https://cdn.hireapp.com
